DATABASE_URL=your_prisma_connection_string

# Supabase Project Configuration
# Copy the real values from the Supabase dashboard's Connect dialog
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_publishable_key
SUPABASE_SECRET_KEY=  # Keep empty, NEVER commit the secret key to git
SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json
